Defaults use_pty
Defaults secure_path="/opt/archpkgs/bin:/usr/local/bin:/usr/bin"
Defaults env_reset
Defaults editor="/usr/bin/nvim:/usr/bin/vim:/usr/bin/vi:/usr/bin/nano"
Defaults passprompt="🔐 Password: "
Defaults passwd_timeout=15
Defaults timestamp_timeout=10
Defaults lecture=never

root ALL=(ALL:ALL) ALL
%wheel ALL=(ALL) ALL

@includedir /etc/sudoers.d
